{
  "redirects": [
    { "source": "/admin", "destination": "/admin/", "permanent": false },
    { "source": "/category/:path*", "destination": "/blog", "permanent": true },
    { "source": "/tag/:path*", "destination": "/blog", "permanent": true },
    { "source": "/:year(\\d{4})/:month(\\d{2})/:slug", "destination": "/blog/:slug", "permanent": true },
    { "source": "/sobre-nos", "destination": "/sobre", "permanent": true },
    { "source": "/sobre-nos/", "destination": "/sobre", "permanent": true },
    { "source": "/servicos-medicos", "destination": "/servicos", "permanent": true },
    { "source": "/servicos-medicos/", "destination": "/servicos", "permanent": true },
    { "source": "/fale-conosco", "destination": "/contato", "permanent": true },
    { "source": "/fale-conosco/", "destination": "/contato", "permanent": true },
    { "source": "/nossa-equipe", "destination": "/equipe", "permanent": true },
    { "source": "/nossa-equipe/", "destination": "/equipe", "permanent": true },
    { "source": "/wp-login.php", "destination": "/", "permanent": true },
    { "source": "/wp-content/:path*", "destination": "/", "permanent": true },
    { "source": "/feed", "destination": "/blog", "permanent": true },
    { "source": "/feed/", "destination": "/blog", "permanent": true }
  ],
  "rewrites": [
    { "source": "/admin/", "destination": "/admin/index.html" },
    { "source": "/((?!api|admin|assets|uploads).*)", "destination": "/index.html" }
  ]
}
